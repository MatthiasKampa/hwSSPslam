__pycache__/
*.pyc
.DS_Store
.claude/
# datasets are fetched, not committed (see data/README.md)
data/*
!data/README.md
!data/fetch_datasets.sh

# ALL transient/throwaway session files (scripts, logs, outputs) live here —
# see PROTOCOL.md rule on scratch hygiene
scratch/

# regenerable trajectory outputs (drivers/experiments write these; rpe.py
# consumes them)
*.npz

# generated replay blobs (embedded into demo/index.html by --embed;
# demo/replays/manifest.json stays tracked — it defines the embed set/order)
demo/replays/replay_*.json

# ice40 build artifacts (bitstreams/pnr reports regenerate from rtl/)
hw/ice40/build/
